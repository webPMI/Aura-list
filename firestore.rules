rules_version = '2';

// Firestore Security Rules for AuraList
// Deploy with: firebase deploy --only firestore:rules
//
// Structure:
// - users/{userId}/tasks/{taskId}
// - users/{userId}/notes/{noteId}
// - users/{userId}/notebooks/{notebookId}
// - users/{userId}/preferences/{prefId}
// - users/{userId}/task_templates/{templateId} (Task templates for reuse)
// - users/{userId}/transactions/{transactionId} (Finance)
// - users/{userId}/categories/{categoryId} (Finance)
// - users/{userId}/recurringTransactions/{docId} (Finance - Auto-repeating transactions)
// - users/{userId}/budgets/{docId} (Finance - Category budgets with alerts)
// - users/{userId}/cashFlowProjections/{docId} (Finance - Future balance predictions)
// - users/{userId}/taskFinanceLinks/{docId} (Finance - Task-finance associations)
// - users/{userId}/financeAlerts/{docId} (Finance - Budget and anomaly alerts)
// - public/guides/{guideId} (Read-only for all, write for admins)
// - public/wellness/{categoryId}/{suggestionId} (Read-only for all, write for admins)
// - admins/{userId} (Admin user registry)

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if user is an admin
    function isAdmin() {
      // Check if the user is in the admins collection
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper function to validate task data
    function isValidTask() {
      let data = request.resource.data;
      return data.title is string
        && data.title.size() > 0
        && data.title.size() <= 500
        && data.type in ['daily', 'weekly', 'monthly', 'yearly', 'once']
        && data.isCompleted is bool
        && data.priority in [0, 1, 2]
        && data.category in ['Personal', 'Trabajo', 'Hogar', 'Salud', 'Otros']
        // Optional soft delete fields
        && (!('deleted' in data.keys()) || data.deleted is bool)
        && (!('deletedAt' in data.keys()) || data.deletedAt is string)
        && (!('lastUpdatedAt' in data.keys()) || data.lastUpdatedAt is string);
    }

    // Helper function to validate note data
    function isValidNote() {
      let data = request.resource.data;
      return data.title is string
        && data.title.size() <= 500
        && data.content is string
        && data.content.size() <= 10000
        && data.isPinned is bool
        // Optional soft delete fields
        && (!('deleted' in data.keys()) || data.deleted is bool)
        && (!('deletedAt' in data.keys()) || data.deletedAt is string);
    }

    // Helper function to validate transaction data
    function isValidTransaction() {
      let data = request.resource.data;
      return data.title is string
        && data.title.size() > 0
        && data.amount is number
        && data.amount > 0
        && data.type in ['expense', 'income']
        && data.categoryId is string
        // Optional fields
        && (!('deleted' in data.keys()) || data.deleted is bool)
        && (!('deletedAt' in data.keys()) || data.deletedAt is string);
    }

    // Helper function to validate finance category data
    function isValidFinanceCategory() {
      let data = request.resource.data;
      return data.id is string
        && data.name is string
        && data.type in ['expense', 'income']
        && data.icon is string
        && data.color is string;
    }

    // Helper function to validate guide data
    function isValidGuide() {
      let data = request.resource.data;
      return data.id is string
        && data.name is string
        && data.title is string
        && data.affinity is string
        && data.themePrimaryHex is string;
    }

    // Helper function to validate wellness data
    function isValidWellness() {
      let data = request.resource.data;
      return data.id is string
        && data.title is string
        && data.description is string
        && data.category is string
        && data.durationMinutes is number
        && data.durationMinutes > 0;
    }

    // User document rules
    match /users/{userId} {
      // Users can only access their own data
      allow read, write: if isAuthenticated() && isOwner(userId);

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId) && isValidTask();
        allow update: if isAuthenticated() && isOwner(userId) && isValidTask();
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Notes subcollection
      match /notes/{noteId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId) && isValidNote();
        allow update: if isAuthenticated() && isOwner(userId) && isValidNote();
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Notebooks subcollection
      match /notebooks/{notebookId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // User preferences subcollection
      match /preferences/{prefId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if isAuthenticated() && isOwner(userId);
      }

      // Finance transactions subcollection
      match /transactions/{transactionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId) && isValidTransaction();
        allow update: if isAuthenticated() && isOwner(userId) && isValidTransaction();
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Finance categories subcollection
      match /categories/{categoryId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId) && isValidFinanceCategory();
        allow update: if isAuthenticated() && isOwner(userId) && isValidFinanceCategory();
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Recurring transactions subcollection
      match /recurringTransactions/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if isAuthenticated() && isOwner(userId);
        // Allow shared access if user is in sharedWith array
        allow read: if isAuthenticated() &&
                      exists(/databases/$(database)/documents/users/$(userId)) &&
                      request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.sharedWith;
      }

      // Budgets subcollection
      match /budgets/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if isAuthenticated() && isOwner(userId);
        // Allow shared access if user is in sharedWith array
        allow read: if isAuthenticated() &&
                      exists(/databases/$(database)/documents/users/$(userId)) &&
                      request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.sharedWith;
      }

      // Cash flow projections subcollection
      match /cashFlowProjections/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Task finance links subcollection
      match /taskFinanceLinks/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Finance alerts subcollection
      match /financeAlerts/{docId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }

      // Task templates subcollection
      match /task_templates/{templateId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
    }

    // ==================== PUBLIC DATA (Read for all authenticated, Write for admins only) ====================

    // Public guides collection
    match /public/guides/{guideId} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      // Only admins can create, update, or delete
      allow create, update: if isAdmin() && isValidGuide();
      allow delete: if isAdmin();
    }

    // Public wellness suggestions
    match /public/wellness/{categoryId}/{suggestionId} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      // Only admins can create, update, or delete
      allow create, update: if isAdmin() && isValidWellness();
      allow delete: if isAdmin();
    }

    // Public wellness categories
    match /public/wellness/categories/{categoryId} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      // Only admins can create, update, or delete
      allow create, update, delete: if isAdmin();
    }

    // Public resources (prompts, tips, updates, etc.)
    match /public/resources/{resourceId=**} {
      // All authenticated users can read
      allow read: if isAuthenticated();
      // Only admins can create, update, or delete
      allow create, update, delete: if isAdmin();
    }

    // ==================== ADMIN COLLECTION ====================

    // Admin users registry
    match /admins/{userId} {
      // All authenticated users can read (to check if someone is admin)
      allow read: if isAuthenticated();
      // Only admins can add/modify/remove admin users
      allow write: if isAdmin();
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
